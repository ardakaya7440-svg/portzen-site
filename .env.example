# PORTZEN Environment Variables
# Bu dosyayı kopyalayıp .env olarak kaydet, gerçek değerleri doldur.
# Asla .env dosyasını GitHub'a yükleme!

# -- Site URL --
NEXT_PUBLIC_SITE_URL=https://portzen.com

# -- Database --
# Local geliştirme için SQLite:
DATABASE_URL=file:./dev.db
# Production için Vercel Postgres veya PostgreSQL:
# DATABASE_URL=postgresql://user:password@host:5432/portzen_prod

# -- Auth --
# En az 64 karakter, rastgele üret:
#   node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
AUTH_SECRET=replace-with-secure-64-char-random-string
NEXTAUTH_URL=https://portzen.com

# -- Admin Credentials --
ADMIN_USERNAME=replace-with-admin-username
ADMIN_PASSWORD=replace-with-strong-password

# -- Vercel Blob (görsel yükleme, isteğe bağlı) --
BLOB_READ_WRITE_TOKEN=
