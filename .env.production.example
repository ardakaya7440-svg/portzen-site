# Production Environment Variables
# Copy this file and fill in real values before deploying.
# NEVER commit the filled .env.production to version control.

# -- Database --
# Vercel Postgres veya başka bir production Postgres URL
DATABASE_URL="postgresql://user:password@host:5432/portzen_prod"

# -- Site URL --
# Gerçek production domain (trailing slash olmadan)
NEXT_PUBLIC_SITE_URL="https://portzen.com"

# -- Auth --
# En az 64 karakter, rastgele oluşturulmuş:
#   node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
AUTH_SECRET=""

# -- Admin Credentials --
# Güçlü, eşsiz bir kullanıcı adı ve şifre kullanın
ADMIN_USERNAME=""
ADMIN_PASSWORD=""

# -- Vercel Blob (görsel yükleme için) --
# Vercel Dashboard > Storage > Blob > Token
BLOB_READ_WRITE_TOKEN=""
